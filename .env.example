# =====================================================================
# Aspire Reporting Hub — environment variable reference
# Copy to `.env.local` (gitignored) and fill in for your environment.
# All VITE_* vars are inlined into the client bundle at build time.
# =====================================================================

# ---------- Keycloak / OIDC ----------
# Realm issuer URL. Must include /realms/<realm>. No trailing slash.
# Example (dev):  http://localhost:8080/realms/aspire
# Example (prod): https://auth.example.com/realms/aspire
VITE_OIDC_AUTHORITY=http://localhost:8080/realms/aspire

# Public client ID configured in Keycloak (Clients → <id>).
VITE_OIDC_CLIENT_ID=aspire-frontend

# Where Keycloak should redirect back after sign-in. Must be whitelisted
# in the Keycloak client's "Valid redirect URIs". Defaults to
# `${window.location.origin}/auth/callback` if unset.
VITE_OIDC_REDIRECT_URI=

# Where to land after sign-out. Must be whitelisted in the Keycloak
# client's "Valid post logout redirect URIs". Defaults to origin.
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=

# OIDC scopes. `roles` is required so realm_access.roles lands in the JWT.
VITE_OIDC_SCOPE=openid profile email roles

# ---------- Backend API ----------
# Base URL for the Aspire backend (Django/Node/etc.). No trailing slash.
# All requests in src/lib/services.ts are relative to this.
VITE_API_BASE_URL=http://localhost:8000/api

# ---------- Orthanc PACS ----------
# Base URL of the Orthanc REST API. The frontend never talks to Orthanc
# directly — the backend proxies all DICOM traffic — but this is surfaced
# in the PACS health dashboard for operators.
VITE_ORTHANC_BASE_URL=http://localhost:8042

# WADO-RS root used by OHIF for image retrieval. Usually
# `${VITE_ORTHANC_BASE_URL}/dicom-web`.
VITE_ORTHANC_WADO_RS_ROOT=http://localhost:8042/dicom-web

# ---------- OHIF Viewer ----------
# Public URL of the OHIF Viewer 3.x deployment. The app prefers a
# backend-minted signed URL from `GET /studies/{id}/viewer-url`, but
# falls back to `${VITE_OHIF_VIEWER_URL}/viewer?StudyInstanceUIDs=…`.
# Example (dev):  http://localhost:3000
# Example (prod): https://viewer.example.com
VITE_OHIF_VIEWER_URL=http://localhost:3000

# ---------- Dev-only ----------
# Set to "true" ONLY in local dev to bypass OIDC with a mock Super Admin
# session. Hard-gated by import.meta.env.DEV — has no effect in prod builds.
VITE_DEV_MODE=false
